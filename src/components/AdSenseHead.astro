---
import { normalizeAdSenseClient } from "../lib/adsense";

const client = normalizeAdSenseClient(import.meta.env.PUBLIC_ADSENSE_CLIENT);
---
{client ? <script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${client}`} crossorigin="anonymous"></script> : null}
