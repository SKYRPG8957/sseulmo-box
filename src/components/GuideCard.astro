---
import type { GuideMeta } from "../data/guides";
interface Props { guide: GuideMeta; }
const { guide } = Astro.props;
---
<article class="panel">
  <p class="text-xs font-semibold text-brand">{guide.category}</p>
  <h3 class="mt-2 text-lg font-semibold leading-snug"><a href={guide.path} class="text-ink no-underline hover:text-brand">{guide.title}</a></h3>
  <p class="mt-2 text-sm leading-6 text-secondary">{guide.description}</p>
  <a href={guide.path} class="btn-secondary mt-4 no-underline">읽기</a>
</article>
