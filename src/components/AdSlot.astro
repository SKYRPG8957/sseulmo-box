---
import { normalizeAdSenseClient, normalizeAdSenseSlot } from "../lib/adsense";

interface Props { label?: string; class?: string; }
const { label = "광고", class: className = "" } = Astro.props;
const client = normalizeAdSenseClient(import.meta.env.PUBLIC_ADSENSE_CLIENT);
const slot = normalizeAdSenseSlot(import.meta.env.PUBLIC_ADSENSE_SLOT);
const showConfiguredSlot = client && slot;
const showSetupPlaceholder = !client;
---
{
  showConfiguredSlot ? (
    <aside class={`my-10 rounded-lg border border-dashed border-slate-300 bg-white p-4 text-center ${className}`} aria-label={label}>
      <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">{label}</div>
      <ins class="adsbygoogle block min-h-24" data-ad-client={client} data-ad-slot={slot} data-ad-format="auto" data-full-width-responsive="true"></ins>
    </aside>
  ) : showSetupPlaceholder ? (
    <aside class={`my-10 rounded-lg border border-dashed border-slate-300 bg-white p-4 text-center ${className}`} aria-label={label}>
      <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">{label}</div>
      <p class="text-sm text-slate-500">광고가 들어갈 자리입니다.</p>
    </aside>
  ) : null
}
