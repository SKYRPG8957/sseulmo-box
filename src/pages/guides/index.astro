---
import Layout from "../../components/Layout.astro";
import GuideCard from "../../components/GuideCard.astro";
import { guides } from "../../data/guides";
---
<Layout title="가이드" description="도구를 쓸 때 같이 보면 좋은 짧은 글입니다." path="/guides">
  <section class="container-page py-8 md:py-10">
    <h1 class="text-3xl font-semibold md:text-4xl">가이드</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-secondary">도구를 쓸 때 같이 보면 좋은 짧은 글입니다.</p>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>
</Layout>
