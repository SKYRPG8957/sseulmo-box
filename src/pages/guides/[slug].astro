---
import Layout from "../../components/Layout.astro";
import RelatedTools from "../../components/RelatedTools.astro";
import { guides } from "../../data/guides";

export function getStaticPaths() {
  return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
---
<Layout title={guide.title} description={guide.description} path={guide.path}>
  <article class="container-page max-w-[820px] py-8 md:py-10">
    <p class="text-sm font-semibold text-brand">{guide.category}</p>
    <h1 class="mt-2 text-3xl font-semibold leading-tight md:text-4xl">{guide.title}</h1>
    <p class="mt-3 text-base leading-7 text-secondary">{guide.description}</p>
    <div class="prose-box mt-8" set:html={guide.body} />
    <RelatedTools slugs={[guide.tool]} />
  </article>
</Layout>
