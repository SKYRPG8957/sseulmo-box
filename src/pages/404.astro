---
import Layout from "../components/Layout.astro";
import ToolCard from "../components/ToolCard.astro";
import { availableTools } from "../data/tools";
---
<Layout title="페이지를 찾을 수 없습니다" description="요청한 페이지를 찾을 수 없습니다. 도구 목록으로 이동할 수 있습니다." path="/404">
  <section class="container-page py-10 md:py-12">
    <h1 class="text-3xl font-semibold md:text-4xl">페이지를 찾을 수 없습니다</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-secondary">주소를 다시 확인하거나 도구 목록에서 필요한 기능을 찾아보세요.</p>
    <a href="/tools" class="btn mt-5 no-underline">도구 목록 보기</a>
    <h2 class="mt-10 text-2xl font-semibold">자주 쓰는 도구</h2>
    <div class="tool-grid mt-4">{availableTools.filter((tool) => tool.featured).slice(0,3).map((tool) => <ToolCard tool={tool} />)}</div>
  </section>
</Layout>
